3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FJamun.png&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/25 group-hover:bg-black/10 transition-colors\"></div></div><p class=\"font-inter text-[0.65rem] font-medium text-stone-300 leading-tight text-center\">Jamun</p><p class=\"font-inter text-[0.55rem] text-stone-600 text-center\">Monsoon</p></div><div class=\"group\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"relative aspect-square rounded-lg overflow-hidden mb-1.5\"><img alt=\"Cashew\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-500 group-hover:scale-110\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"12vw\" srcSet=\"/_next/image?url=%2Fimages%2FCashew.jpg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FCashew.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FCashew.jpg&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/25 group-hover:bg-black/10 transition-colors\"></div></div><p class=\"font-inter text-[0.65rem] font-medium text-stone-300 leading-tight text-center\">Cashew</p><p class=\"font-inter text-[0.55rem] text-stone-600 text-center\">Cold-pressed</p></div><div class=\"group\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"relative aspect-square rounded-lg overflow-hidden mb-1.5\"><img alt=\"Sita Phal\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-500 group-hover:scale-110\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"12vw\" srcSet=\"/_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FSitafal.jpg&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/25 group-hover:bg-black/10 transition-colors\"></div></div><p class=\"font-inter text-[0.65rem] font-medium text-stone-300 leading-tight text-center\">Sita Phal</p><p class=\"font-inter text-[0.55rem] text-stone-600 text-center\">Sep–Nov</p></div><div class=\"group\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"relative aspect-square rounded-lg overflow-hidden mb-1.5\"><img alt=\"Lakshman Phal\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-500 group-hover:scale-110\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"12vw\" srcSet=\"/_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FLakshmanPhal.jpg&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/25 group-hover:bg-black/10 transition-colors\"></div></div><p class=\"font-inter text-[0.65rem] font-medium text-stone-300 leading-tight text-center\">Lakshman Phal</p><p class=\"font-inter text-[0.55rem] text-stone-600 text-center\">Rare tropical</p></div></div><div class=\"mt-12 grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-stone-800 border border-stone-800 rounded-xl overflow-hidden\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"bg-stone-800/50 px-6 py-5\"><span class=\"text-lg mb-2 block\">🌱</span><h4 class=\"font-playfair text-stone-200 text-sm font-semibold mb-1\">Soil Health</h4><p class=\"font-inter text-stone-500 text-xs leading-relaxed\">Enriched only with our own cow manure and on-farm compost.</p></div><div class=\"bg-stone-800/50 px-6 py-5\"><span class=\"text-lg mb-2 block\">💧</span><h4 class=\"font-playfair text-stone-200 text-sm font-semibold mb-1\">Water</h4><p class=\"font-inter text-stone-500 text-xs leading-relaxed\">Drip irrigation and rainwater harvesting replenish the groundwater.</p></div><div class=\"bg-stone-800/50 px-6 py-5\"><span class=\"text-lg mb-2 block\">🚫</span><h4 class=\"font-playfair text-stone-200 text-sm font-semibold mb-1\">Zero Chemicals</h4><p class=\"font-inter text-stone-500 text-xs leading-relaxed\">Organic-certification ready — every harvest free of pesticides.</p></div></div></div></section><section id=\"cows\" class=\"py-20 md:py-28 bg-[#FDFBF7] border-t border-stone-100\"><div class=\"max-w-6xl mx-auto px-6 md:px-10\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center\"><div style=\"opacity:0;transform:translateX(-24px)\"><div class=\"relative rounded-xl overflow-hidden bg-stone-100\"><div class=\"relative h-72\" style=\"opacity:0\"><img alt=\"Gauri\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcSet=\"/_next/image?url=%2Fimages%2FGauri.jpg&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FGauri.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FGauri.jpg&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent\"></div><div class=\"absolute bottom-0 left-0 right-0 p-5\"><p class=\"font-playfair text-white text-xl\">Gauri</p><p class=\"font-inter text-white/65 text-xs mt-0.5\">Rescued 2021 — gentle matriarch of the goshala.</p></div></div><button type=\"button\" aria-label=\"Previous cow\" class=\"absolute top-1/2 left-3 -translate-y-1/2 w-8 h-8 rounded-full bg-white/15 hover:bg-white/30 text-white backdrop-blur-sm flex items-center justify-center transition-colors\">‹</button><button type=\"button\" aria-label=\"Next cow\" class=\"absolute top-1/2 right-3 -translate-y-1/2 w-8 h-8 rounded-full bg-white/15 hover:bg-white/30 text-white backdrop-blur-sm flex items-center justify-center transition-colors\">›</button></div><div class=\"flex justify-center gap-2 mt-3\"><button type=\"button\" aria-label=\"Go to Gauri\" class=\"transition-all duration-300 rounded-full w-5 h-1.5 bg-terracotta\"></button><button type=\"button\" aria-label=\"Go to Krishna\" class=\"transition-all duration-300 rounded-full w-1.5 h-1.5 bg-stone-300\"></button></div></div><div class=\"space-y-5\" style=\"opacity:0;transform:translateX(24px)\"><span class=\"font-inter label-eyebrow\">Living with Reverence</span><h2 class=\"font-playfair text-3xl md:text-4xl text-stone-900 leading-tight\">More Than a Goshala,<br/><span class=\"text-forest\">It&#x27;s a Family</span></h2><p class=\"font-inter text-stone-600 leading-relaxed text-sm\">Our desi cows roam freely on open pasture, never separated from their calves. The A2 milk they give flows only when the calf has taken its fill.</p><blockquote class=\"border-l-2 border-stone-200 pl-4\"><p class=\"font-prose text-stone-500 text-sm italic leading-relaxed\">“They bring us peace and rhythm.”</p><footer class=\"font-inter text-stone-400 text-[0.6rem] tracking-widest uppercase mt-1.5\">— Sudha &amp; Girish</footer></blockquote><div class=\"flex gap-6\"><div><p class=\"font-playfair text-stone-800 font-semibold text-sm\">Desi / Gir</p><p class=\"font-inter text-[0.6rem] text-stone-400 tracking-widest uppercase mt-0.5\">Breed</p></div><div><p class=\"font-playfair text-stone-800 font-semibold text-sm\">A2 only</p><p class=\"font-inter text-[0.6rem] text-stone-400 tracking-widest uppercase mt-0.5\">Milk</p></div><div><p class=\"font-playfair text-stone-800 font-semibold text-sm\">Ahimsa</p><p class=\"font-inter text-[0.6rem] text-stone-400 tracking-widest uppercase mt-0.5\">Practice</p></div></div><button type=\"button\" class=\"font-inter text-xs text-amber-800 border border-amber-200 px-4 py-2 rounded-full hover:bg-amber-50 transition-colors\">Future: The SuDhama Dairy →</button></div></div></div></section><section id=\"story\" class=\"py-20 md:py-28 bg-stone-50 border-t border-stone-100\"><div class=\"max-w-6xl mx-auto px-6 md:px-10\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start\"><div class=\"space-y-5\" style=\"opacity:0;transform:translateY(20px)\"><span class=\"font-inter label-eyebrow\">How It Began</span><h2 class=\"font-playfair text-3xl md:text-4xl text-stone-900 leading-tight\">The Second Innings</h2><p class=\"font-inter text-stone-600 leading-relaxed text-sm\">After decades in the city, Sudha &amp; Girish felt a calling — to return to their roots, cultivate a life of purpose, and live in honest connection with the earth.</p><div class=\"space-y-4 pt-2\"><div class=\"flex items-center gap-4\" style=\"opacity:0;transform:translateX(-12px)\"><span class=\"font-inter font-bold text-terracotta w-12 text-sm flex-shrink-0\">2019</span><div class=\"h-px flex-1 bg-stone-200\"></div><span class=\"font-inter text-stone-500 text-sm\">Left city life behind</span></div><div class=\"flex items-center gap-4\" style=\"opacity:0;transform:translateX(-12px)\"><span class=\"font-inter font-bold text-terracotta w-12 text-sm flex-shrink-0\">2021</span><div class=\"h-px flex-1 bg-stone-200\"></div><span class=\"font-inter text-stone-500 text-sm\">First rescue cow, Gauri</span></div><div class=\"flex items-center gap-4\" style=\"opacity:0;transform:translateX(-12px)\"><span class=\"font-inter font-bold text-terracotta w-12 text-sm flex-shrink-0\">2023</span><div class=\"h-px flex-1 bg-stone-200\"></div><span class=\"font-inter text-stone-500 text-sm\">First full organic harvest</span></div></div></div><div class=\"bg-white border border-stone-100 rounded-2xl p-8 space-y-4 shadow-sm\" style=\"opacity:0;transform:translateY(20px)\"><p class=\"font-inter text-[0.6rem] tracking-[0.3em] uppercase text-stone-400\">Founder&#x27;s Note</p><blockquote class=\"space-y-3\"><p class=\"font-prose text-stone-600 leading-relaxed text-[0.925rem] italic\">“The decision to leave our urban life behind was not easy, but it was necessary. We felt a calling to return to our roots — to cultivate a life of purpose and intention.</p><p class=\"font-prose text-stone-600 leading-relaxed text-[0.925rem] italic\">SuDhama is our answer to that call. A testament to the power of nature to heal, inspire, and transform.”</p></blockquote><footer class=\"flex items-center gap-3 pt-2\"><div class=\"w-6 h-px bg-terracotta\"></div><span class=\"font-playfair text-stone-800 text-sm\">Sudha &amp; Girish</span></footer></div></div></div></section><section id=\"location\" class=\"py-20 md:py-28 border-t border-stone-100\"><div class=\"max-w-6xl mx-auto px-6 md:px-10\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start\"><div class=\"space-y-6\" style=\"opacity:0;transform:translateY(20px)\"><div><span class=\"font-inter label-eyebrow\">Where We Are</span><h2 class=\"font-playfair text-3xl md:text-4xl text-stone-900 leading-tight\">Find Us</h2></div><address class=\"not-italic space-y-1\"><p class=\"font-playfair text-stone-900 font-semibold\">SuDhama</p><p class=\"font-inter text-stone-600 text-sm leading-relaxed\">8-118(1), Kanyana Village,<br/>Near Peradi, Hebri Taluk,<br/>Udupi District, Karnataka — 576112</p></address><div class=\"flex items-start gap-3\"><span class=\"text-base mt-0.5\">✉️</span><div><p class=\"font-inter text-[0.6rem] uppercase tracking-widest text-stone-400 font-medium\">Email</p><a href=\"mailto:contact@sudhamafarms.com\" class=\"font-inter text-stone-700 text-sm hover:text-terracotta transition-colors\">contact@sudhamafarms.com</a></div></div><a href=\"https://www.google.com/maps/place/%E0%B2%B8%E0%B3%81%E0%B2%A7%E0%B2%BE%E0%B2%AE/@13.4247466,74.9705411,172m/data=!3m1!1e3!4m6!3m5!1s0x3bbb5f0028f20293:0x1f97240b6ea82aa0!8m2!3d13.424356!4d74.9707893!16s%2Fg%2F11xdm06wx3?entry=ttu\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"font-inter inline-flex items-center gap-2 text-sm px-5 py-2.5 bg-forest text-white rounded-full hover:bg-forest/90 transition-colors\">Open in Google Maps</a></div><div class=\"rounded-xl overflow-hidden border border-stone-200 shadow-sm\" style=\"height:320px;opacity:0;transform:scale(0.98)\"><iframe title=\"SuDhama satellite map\" src=\"https://maps.google.com/maps?q=13.424356,74.9707893&amp;t=k&amp;z=17&amp;ie=UTF8&amp;iwloc=&amp;output=embed\" width=\"100%\" height=\"100%\" loading=\"lazy\" referrerPolicy=\"no-referrer-when-downgrade\" class=\"border-0 block\"></iframe></div></div></div></section><!--$--><!--/$--></main><footer class=\"bg-stone-900 text-stone-400 py-14 mt-0 border-t border-stone-800\"><div class=\"max-w-6xl mx-auto px-6 md:px-10\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-stone-800\"><div class=\"space-y-3\"><img alt=\"SuDhama\" loading=\"lazy\" width=\"88\" height=\"40\" decoding=\"async\" data-nimg=\"1\" class=\"h-10 w-auto brightness-[2] opacity-80\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=96&amp;q=75 1x, /_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75\"/><p class=\"text-stone-500 text-xs leading-relaxed max-w-[220px]\">A good home. A good life.<br/>Kanyana Village, Udupi.</p></div><div><p class=\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\">Navigate</p><ul class=\"space-y-2\"><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#farmhouse\">The Farmhouse</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#farm\">Our Farm</a></li><li><a class