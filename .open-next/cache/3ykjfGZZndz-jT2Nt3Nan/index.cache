{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><!--3ykjfGZZndz_jT2Nt3Nan--><html lang=\"en\" class=\"scroll-smooth\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=16&amp;q=75 16w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=3840&amp;q=75 3840w\" imageSizes=\"32px\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FFarm.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FFarm.jpg&amp;w=3840&amp;q=75 3840w\" imageSizes=\"100vw\"/><link rel=\"stylesheet\" href=\"/_next/static/css/c7b65dae731102a0.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4772d34723bd25e0.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f84124391a7dac4.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-9b1b44b67a62221e.js\" async=\"\"></script><script src=\"/_next/static/chunks/205-40222df77b709121.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/239-0efcf3b33fe933aa.js\" async=\"\"></script><script src=\"/_next/static/chunks/845-b60c57e3c3d88dde.js\" async=\"\"></script><script src=\"/_next/static/chunks/519-a2fc4ab551bfbf28.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-c2b48f79f529a79f.js\" async=\"\"></script><script src=\"/_next/static/chunks/816-1f1e994616b2b935.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-31ba91eaa2e6307f.js\" async=\"\"></script><title>SuDhama: The Good Home</title><meta name=\"description\" content=\"SuDhama is a sanctuary in the heart of Udupi — organic produce, heritage cows, and the slow life, rooted in tradition and affection for the land.\"/><meta property=\"og:title\" content=\"SuDhama: The Good Home\"/><meta property=\"og:description\" content=\"SuDhama is a sanctuary in the heart of Udupi — organic produce, heritage cows, and the slow life, rooted in tradition and affection for the land.\"/><meta property=\"og:site_name\" content=\"SuDhama\"/><meta property=\"og:locale\" content=\"en_IN\"/><meta property=\"og:image\" content=\"https://sudhamafarms.com/images/Farmhouse.jpg\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"SuDhama Farmhouse\"/><meta property=\"og:type\" conten