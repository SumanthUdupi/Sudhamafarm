mb-10\"><button class=\"px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-terracotta text-white\">All</button><button class=\"px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-stone-200 text-stone-500 hover:border-terracotta hover:text-terracotta\">Pilgrimage</button><button class=\"px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-stone-200 text-stone-500 hover:border-terracotta hover:text-terracotta\">Temple</button></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7\"><article style=\"opacity:0;transform:translateY(24px)\"><a class=\"group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition-shadow\" href=\"/blog/maa-biraja-shakti-peetha\"><div class=\"relative aspect-[3/2] overflow-hidden\"><img alt=\"Maa Biraja: The Navel of the World\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-106\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1605330889276-80dc48464670%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div></div><div class=\"p-6\"><div class=\"flex items-center gap-2 mb-3\"><span class=\"text-xs text-terracotta font-medium tracking-wide uppercase\">Pilgrimage</span><span class=\"text-stone-200\">·</span><span class=\"text-xs text-stone-400\">📍 <!-- -->Jajpur, Odisha</span></div><h2 class=\"font-display text-xl text-warm-stone leading-tight group-hover:text-terracotta transition-colors\">Maa Biraja: The Navel of the World</h2><p class=\"mt-2 text-sm text-stone-400 line-clamp-3 leading-relaxed\">Among the 51 Shakti Peethas, Maa Biraja at Jajpur holds a singular position — it is said to mark the spot where the navel of the goddess fell to earth.</p><div class=\"mt-4 flex items-center justify-between text-xs text-stone-300\"><span>1 May 2024</span><span class=\"text-terracotta opacity-0 group-hover:opacity-100 transition-opacity\">Read →</span></div></div></a></article><article style=\"opacity:0;transform:translateY(24px)\"><a class=\"group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition-shadow\" href=\"/blog/chausath-yogini-temple\"><div class=\"relative aspect-[3/2] overflow-hidden\"><img alt=\"The Sixty-Four Yoginis of Hirapur\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-106\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div></div><div class=\"p-6\"><div class=\"flex items-center gap-2 mb-3\"><span class=\"text-xs text-terracotta font-medium tracking-wide uppercase\">Temple</span><span class=\"text-stone-200\">·</span><span class=\"text-xs text-stone-400\">📍 <!-- -->Hirapur, Odisha</span></div><h2 class=\"font-display text-xl text-warm-stone leading-tight group-hover:text-terracotta transition-colors\">The Sixty-Four Yoginis of Hirapur</h2><p class=\"mt-2 text-sm text-stone-400 line-clamp-3 leading-relaxed\">Hidden in a field nine kilometres from Bhubaneswar, a circular roofless temple holds sixty-four yoginis in sandstone — among the rarest religious sites in India.</p><div class=\"mt-4 flex items-center justify-between text-xs text-stone-300\"><span>5 Apr 2024</span><span class=\"text-terracotta opacity-0 group-hover:opacity-100 transition-opacity\">Read →</span></div></div></a></article><article style=\"opacity:0;transform:translateY(24px)\"><a class=\"group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition-shadow\" href=\"/blog/puri-jagannath-temple\"><div class=\"relative aspect-[3/2] overflow-hidden\"><img alt=\"Puri: The Lord&#x27;s Abode\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-106\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1566804968393-27d9753c2289%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div></div><div class=\"p-6\"><div class=\"flex items-center gap-2 mb-3\"><span class=\"text-xs text-terracotta font-medium tracking-wide uppercase\">Pilgrimage</span><span class=\"text-stone-200\">·</span><span class=\"text-xs text-stone-400\">📍 <!-- -->Puri, Odisha</span></div><h2 class=\"font-display text-xl text-warm-stone leading-tight group-hover:text-terracotta transition-colors\">Puri: The Lord&#x27;s Abode</h2><p class=\"mt-2 text-sm text-stone-400 line-clamp-3 leading-relaxed\">Where the Char Dham meets the sea — a journey to the sacred kingdom of Lord Jagannath, master of the universe.</p><div class=\"mt-4 flex items-center justify-between text-xs text-stone-300\"><span>15 Mar 2024</span><span class=\"text-terracotta opacity-0 group-hover:opacity-100 transition-opacity\">Read →</span></div></div></a></article><article style=\"opacity:0;transform:translateY(24px)\"><a class=\"group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition-shadow\" href=\"/blog/konark-sun-temple\"><div class=\"relative aspect-[3/2] overflow-hidden\"><img alt=\"Konark: The Sun Chariot\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-106\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1591807353982-bfa33e83b4c6%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div></div><div class=\"p-6\"><div class=\"flex items-center gap-2 mb-3\"><span class=\"text-xs text-terracotta font-medium tracking-wide uppercase\">Temple</span><span class=\"text-stone-200\">·</span><span class=\"text-xs text-stone-400\">📍 <!-- -->Konark, Odisha</span></div><h2 class=\"font-display text-xl text-warm-stone leading-tight group-hover:text-terracotta transition-colors\">Konark: The Sun Chariot</h2><p class=\"mt-2 text-sm text-stone-400 line-clamp-3 leading-relaxed\">A 13th-century stone chariot built to carry the god of light across the sky — and what remains when the light itself has faded.</p><div class=\"mt-4 flex items-center justify-between text-xs text-stone-300\"><span>20 Feb 2024</span><span class=\"text-terracotta opacity-0 group-hover:opacity-100 transition-opacity\">Read →</span></div></div></a></article><article style=\"opacity:0;transform:translateY(24px)\"><a class=\"group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition-shadow\" href=\"/blog/lingaraj-temple\"><div class=\"relative aspect-[3/2] overflow-hidden\"><img alt=\"Lingaraj: The King of Lingas\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-106\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1627894483216-2138af692e32%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div></div><div class=\"p-6\"><div class=\"flex items-center gap-2 mb-3\"><span class=\"text-xs text-terracotta font-medium tracking-wide uppercase\">Temple</span><span class=\"text-stone-200\">·</span><span class=\"text-xs text-stone-400\">📍 <!-- -->Bhubaneswar, Odisha</span></div><h2 class=\"font-display text-xl text-warm-stone leading-tight group-hover:text-terracotta transition-colors\">Lingaraj: The King of Lingas</h2><p class=\"mt-2 text-sm text-stone-400 line-clamp-3 leading-relaxed\">Bhubaneswar&#x27;s oldest and largest temple is a living monument — thousands gather here daily, as they have for eleven centuries.</p><div class=\"mt-4 flex items-center justify-between text-xs text-stone-300\"><span>10 Jan 2024</span><span class=\"text-terracotta opacity-0 group-hover:opacity-100 transition-opacity\">Read →</span></div></div></a></article><article style=\"opacity:0;transform:translateY(24px)\"><a class=\"group block rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition-shadow\" href=\"/blog/odisha-sacred-odyssey\"><div class=\"relative aspect-[3/2] overflow-hidden\"><img alt=\"An Odisha Sacred Odyssey\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover transition-transform duration-700 group-hover:scale-106\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1477587458883-47145ed94245%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\"></div></div><div class=\"p-6\"><div class=\"flex items-center gap-2 mb-3\"><span class=\"text-xs text-terracotta font-medium tracking-wide uppercase\">Pilgrimage</span><span class=\"text-stone-200\">·</span><span class=\"text-xs text-stone-400\">📍 <!-- -->Odisha, India</span></div><h2 class=\"font-display text-xl text-warm-stone leading-tight group-hover:text-terracotta transition-colors\">An Odisha Sacred Odyssey</h2><p class=\"mt-2 text-sm text-stone-400 line-clamp-3 leading-relaxed\">From the temple-city of Bhubaneswar to the ocean at Puri, a journey through the living architecture of eastern India&#x27;s spiritual heritage.</p><div class=\"mt-4 flex items-center justify-between text-xs text-stone-300\"><span>1 Jan 2024</span><span class=\"text-terracotta opacity-0 group-hover:opacity-100 transition-opacity\">Read →</span></div></div></a></article></div></div></div></div><!--$--><!--/$--></main><footer class=\"bg-stone-900 text-stone-400 py-14 mt-0 border-t border-stone-800\"><div class=\"max-w-6xl mx-auto px-6 md:px-10\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-stone-800\"><div class=\"space-y-3\"><img alt=\"SuDhama\" loading=\"lazy\" width=\"88\" height=\"40\" decoding=\"async\" data-nimg=\"1\" class=\"h-10 w-auto brightness-[2] opacity-80\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=96&amp;q=75 1x, /_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75\"/><p class=\"text-stone-500 text-xs leading-relaxed max-w-[220px]\">A good home. A good life.<br/>Kanyana Village, Udupi.</p></div><div><p class=\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\">Navigate</p><ul class=\"space-y-2\"><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#farmhouse\">The Farmhouse</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#farm\">Our Farm</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#cows\">Our Cows</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#story\">Our Story</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/blog\">Sacred Journeys</a></li></ul></div><div><p class=\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\">Contact</p><address class=\"not-italic text-sm text-stone-400 leading-relaxed space-y-1\"><p>Kanyana Village, Hebri Taluk</p><p>Udupi, Karnataka — 576112</p><a href=\"mailto:contact@sudhamafarms.com\" class=\"block mt-2 hover:text-white transition-colors\">contact@sudhamafarms.com</a></address></div></div><div class=\"pt-6 flex flex-col sm:flex-row justify-between text-[0.65rem] text-stone-600 tracking-wide\"><p>© <!-- -->2026<!-- --> SuDhama. All rights reserved.</p><p class=\"mt-2 sm:mt-0\">Hebri · Udupi · Karnataka</p></div></div></footer><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><script src=\"/_next/static/chunks/webpack-4772d34723bd25e0.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[3183,[\\\"205\\\",\\\"static/chunks/205-40222df77b709121.js\\\",\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"239\\\",\\\"static/chunks/239-0efcf3b33fe933aa.js\\\",\\\"845\\\",\\\"static/chunks/845-b60c57e3c3d88dde.js\\\",\\\"519\\\",\\\"static/chunks/519-a2fc4ab551bfbf28.js\\\",\\\"177\\\",\\\"static/chunks/app/layout-c2b48f79f529a79f.js\\\"],\\\"QueryProvider\\\"]\\n3:I[7277,[\\\"205\\\",\\\"static/chunks/205-40222df77b709121.js\\\",\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"239\\\",\\\"static/chunks/239-0efcf3b33fe933aa.js\\\",\\\"845\\\",\\\"static/chunks/845-b60c57e3c3d88dde.js\\\",\\\"519\\