enter text-center px-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-8xl font-display text-stone-200 select-none\\\",\\\"children\\\":\\\"404\\\"}],[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"mt-4 text-2xl font-display text-warm-stone\\\",\\\"children\\\":\\\"Page not found\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-2 text-stone-500 max-w-sm\\\",\\\"children\\\":\\\"The path you followed leads to still water. Return to where the land is known.\\\"}],[\\\"$\\\",\\\"$L7\\\",null,{\\\"href\\\":\\\"/\\\",\\\"className\\\":\\\"mt-8 px-6 py-3 rounded-full border border-terracotta text-terracotta hover:bg-terracotta hover:text-white transition-colors text-sm\\\",\\\"children\\\":\\\"Return home\\\"}]]}],[]],\\\"forbidden\\\":\\\"$undefined\\\",\\\"unauthorized\\\":\\\"$undefined\\\"}]}],[\\\"$\\\",\\\"footer\\\",null,{\\\"className\\\":\\\"bg-stone-900 text-stone-400 py-14 mt-0 border-t border-stone-800\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-6xl mx-auto px-6 md:px-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-stone-800\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L8\\\",null,{\\\"src\\\":\\\"/images/Logo.png\\\",\\\"alt\\\":\\\"SuDhama\\\",\\\"width\\\":88,\\\"height\\\":40,\\\"className\\\":\\\"h-10 w-auto brightness-[2] opacity-80\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-stone-500 text-xs leading-relaxed max-w-[220px]\\\",\\\"children\\\":[\\\"A good home. A good life.\\\",[\\\"$\\\",\\\"br\\\",null,{}],\\\"Kanyana Village, Udupi.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\\\",\\\"children\\\":\\\"Navigate\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"/#farmhouse\\\",{\\\"children\\\":[\\\"$\\\",\\\"$L7\\\",null,{\\\"href\\\":\\\"/#farmhouse\\\",\\\"className\\\":\\\"text-sm text-stone-400 hover:text-white transition-colors\\\",\\\"children\\\":\\\"The Farmhouse\\\"}]}],[\\\"$\\\",\\\"li\\\",\\\"/#farm\\\",{\\\"children\\\":[\\\"$\\\",\\\"$L7\\\",null,{\\\"href\\\":\\\"/#farm\\\",\\\"className\\\":\\\"text-sm text-stone-400 hover:text-white transition-colors\\\",\\\"children\\\":\\\"Our Farm\\\"}]}],[\\\"$\\\",\\\"li\\\",\\\"/#cows\\\",{\\\"children\\\":[\\\"$\\\",\\\"$L7\\\",null,{\\\"href\\\":\\\"/#cows\\\",\\\"className\\\":\\\"text-sm text-stone-400 hover:text-white transition-colors\\\",\\\"children\\\":\\\"Our Cows\\\"}]}],[\\\"$\\\",\\\"li\\\",\\\"/#story\\\",{\\\"children\\\":[\\\"$\\\",\\\"$L7\\\",null,{\\\"href\\\":\\\"/#story\\\",\\\"className\\\":\\\"text-sm text-stone-400 hover:text-white transition-colors\\\",\\\"children\\\":\\\"Our Story\\\"}]}],[\\\"$\\\",\\\"li\\\",\\\"/blog\\\",{\\\"children\\\":[\\\"$\\\",\\\"$L7\\\",null,{\\\"href\\\":\\\"/blog\\\",\\\"className\\\":\\\"text-sm text-stone-400 hover:text-white transition-colors\\\",\\\"children\\\":\\\"Sacred Journeys\\\"}]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\\\",\\\"children\\\":\\\"Contact\\\"}],[\\\"$\\\",\\\"address\\\",null,{\\\"className\\\":\\\"not-italic text-sm text-stone-400 leading-relaxed space-y-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Kanyana Village, Hebri Taluk\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Udupi, Karnataka — 576112\\\"}],[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"mailto:contact@sudhamafarms.com\\\",\\\"className\\\":\\\"block mt-2 hover:text-white transition-colors\\\",\\\"children\\\":\\\"contact@sudhamafarms.com\\\"}]]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"pt-6 flex flex-col sm:flex-row justify-between text-[0.65rem] text-stone-600 tracking-wide\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"© \\\",2026,\\\" SuDhama. All rights reserved.\\\"]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-2 sm:mt-0\\\",\\\"children\\\":\\\"Hebri · Udupi · Karnataka\\\"}]]}]]}]}],[\\\"$\\\",\\\"$L9\\\",null,{}],[\\\"$\\\",\\\"$La\\\",null,{\\\"position\\\":\\\"bottom-right\\\",\\\"richColors\\\":true,\\\"closeButton\\\":true}]]}]}]}]]}],{\\\"children\\\":[\\\"blog\\\",[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[null,[\\\"$\\\",\\\"$L5\\\",null,{\\\"parallelRouterKey\\\":\\\"children\\\",\\\"error\\\":\\\"$undefined\\\",\\\"errorStyles\\\":\\\"$undefined\\\",\\\"errorScripts\\\":\\\"$undefined\\\",\\\"template\\\":\\\"$Lb\\\",\\\"templateStyles\\\":\\\"$undefined\\\",\\\"templateScripts\\\":\\\"$undefined\\\",\\\"notFound\\\":\\\"$undefined\\\",\\\"forbidden\\\":\\\"$undefined\\\",\\\"unauthorized\\\":\\\"$undefined\\\"}]]}],{\\\"children\\\":[\\\"__PAGE__\\\",\\\"$Lc\\\",{},null,false]},null,false]},null,false],\\\"$Ld\\\",false]],\\\"m\\\":\\\"$undefined\\\",\\\"G\\\":[\\\"$e\\\",[]],\\\"s\\\":false,\\\"S\\\":true}\\n\"])</script><script>self.__next_f.push([1,\"f:I[2708,[\\\"205\\\",\\\"static/chunks/205-40222df77b709121.js\\\",\\\"619\\\",\\\"static/chunks/619-ba102abea3e3d0e4.js\\\",\\\"239\\\",\\\"static/chunks/239-0efcf3b33fe933aa.js\\\",\\\"831\\\",\\\"static/chunks/app/blog/page-c6b0d4c8c464e70f.js\\\"],\\\"default\\\"]\\n17:I[4431,[],\\\"ViewportBoundary\\\"]\\n19:I[4431,[],\\\"MetadataBoundary\\\"]\\n1a:\\\"$Sreact.suspense\\\"\\nb:[\\\"$\\\",\\\"$L6\\\",null,{}]\\n10:Tb19,\"])</script><script>self.__next_f.push([1,\"\\n## The Myth of the Scattered Goddess\\n\\nThe theology behind the Shakti Peethas is one of the most powerful origin stories in Indian religion. When Sati — the consort of Shiva — died by self-immolation, Shiva's grief threatened to destroy the universe. To end his mourning, Lord Vishnu used his *sudarshana chakra* to dismember her body as Shiva carried it, scattering the pieces across the Indian subcontinent.\\n\\nWherever a part of the goddess fell, a temple arose. These are the 51 Shakti Peethas — a geography of sacred grief, a map of the divine body overlaid on the body of the earth.\\n\\nAt Jajpur, it is said that the navel fell. The word *nabhi* — navel — is both anatomical and cosmological: the navel is the source, the origin, the point from which life unfolds. Maa Biraja is therefore not merely a regional goddess but a claim about the centre of the world.\\n\\n## The Temple at Biraja Kshetra\\n\\nThe current temple structure is relatively modern — rebuilt and expanded over centuries — but the site is ancient. The deity, Maa Biraja, is depicted in eight-armed form, representing the eight directions and the totality of the cosmos.\\n\\nWhat strikes the visitor immediately is the devotional intensity here. Unlike the more tourist-oriented Jagannath complex or the archaeologically managed Konark, Biraja Kshetra is a working pilgrimage centre attended primarily by local and regional devotees. The rituals are continuous. The *arati* (lamp ceremony) is performed multiple times a day with a fervour that does not perform itself for the camera.\\n\\n## The Vaitarani River\\n\\nJajpur sits at the confluence of sacred rivers, including the Vaitarani — the river that, in Hindu cosmology, one must cross to reach the realm of the dead. Ritual bathing here, particularly during the monsoon months, draws enormous crowds.\\n\\nI arrived during a quiet weekday, without the crowds. The priests were unhurried and generous with explanations. An elderly woman nearby had been performing a forty-day vow — visiting the temple daily, fasting from sunset to sunrise — and was on her thirty-seventh day. She showed me her log: dates and prayers recorded in a worn notebook, precise as a scientific experiment.\\n\\n## What the Goddess Demands\\n\\nPeople bring impossible things to Maa Biraja. They bring sick children and failing businesses and broken marriages. They bring their accumulated sorrow in the form of coconuts and flowers and promises.\\n\\nThe goddess makes no obvious reply. The lamps burn. The bells ring. The priests chant. And somehow, in ways that resist documentation, people go home carrying something they didn't arrive with.\\n\\nI don't know what to call that something. I know that I felt it too.\\n\\n---\\n\\n*Jajpur is approximately 100 km from Bhubaneswar on NH-16. Temple open daily; Navratri (October) is the primary festival season.*\\n\"])</script><script>self.__next_f.push([1,\"11:Taf7,\"])</script><script>self.__next_f.push([1,\"\\n## What the Fields Hide\\n\\nThere is no signboard that adequately prepares you. You turn off the main road at a junction marked only by a chai stall, follow a narrow track through rice fields, and then — in a clearing, surrounded by nothing remarkable — you find it.\\n\\nThe Chausath Yogini Temple at Hirapur is circular. It is roofless. It is barely nine metres in diameter. And it contains sixty-four yogini figures carved into niches along its inner wall that are unlike anything else in Indian religious art.\\n\\n## The Yoginis Themselves\\n\\nEach of the sixty-four is a form of the divine feminine — powerful, autonomous, iconographically distinct. They carry different weapons, wear different expressions, stand on different vahanas (animal vehicles). Some are serene. Several are terrifying. A few are explicitly erotic. All are carved with a roughness, an immediacy, that differs sharply from the refined polish of mainstream temple sculpture.\\n\\nYogini worship belongs to the Tantric tradition — a strand of Indian spirituality that has always occupied the boundary between the sanctioned and the transgressive. The yoginis are practitioners, not passive figures. They hold power. Their iconography reflects this.\\n\\nThe presiding goddess stands in the centre of the inner courtyard: Maheshvari, eight-armed, above a buffalo. The quality of light that enters this roofless space falls differently depending on the time of day, illuminating different figures as the sun moves.\\n\\n## The Archaeology\\n\\nThe temple dates to approximately the 9th century CE. It was rediscovered by scholars only in 1953. There is a second, less-visited Chausath Yogini temple at Ranipur-Jharial in western Odisha; the two are the only circular yogini temples that survive in India.\\n\\nWhy circular? The form may reflect a ritual practice in which initiates circumambulated the figures during ceremony. Or it may be cosmological — the circle as mandala, the sixty-four as a numerological completeness. The texts are silent on this. The temple simply stands.\\n\\n## The Silence Here\\n\\nI arrived on a weekday afternoon. There was one other visitor, a young woman from Kolkata doing her PhD on Tantric iconography. The caretaker sat under a tree outside, reading a newspaper.\\n\\nInside the circle, the only sound was wind through the open roof. The yoginis looked outward from their niches, toward the rice fields, toward the distant highway, toward whatever they have been looking at for eleven hundred years.\\n\\nI sat on the floor in the centre of the circle for a long time, not meditating exactly, just being still in a place that asked for stillness.\\n\\nThe woman from Kolkata came and sat nearby. We didn't speak. We didn't need to.\\n\\n---\\n\\n*Location: Hirapur village, ~9 km from Bhubaneswar. ASI protected. Open daily sunrise to sunset.*\\n\"])</script><script>self.__next_f.push([1,\"12:Tb9f,\"])</script><script>self.__next_f.push([1,\"\\n## The Grand Road\\n\\nThey call it *Bada Danda* — the Grand Road. It stretches from the eastern gate of the Jagannath Temple all the way to the Gundicha Temple, a distance of three kilometres that, on the day of Rath Yatra, becomes the most densely populated strip of earth on the planet.\\n\\nI arrived in Puri in the early morning hours, before the pilgrimage crowds woke. The town smelled of salt air and burning ghee. The lanes leading to the Singhadwara — the Lion Gate — were already filling with flower sellers and prasad shops, their pyramids of laddus wrapped in red cloth catching the first light.\\n\\n## The Four Gates\\n\\nThe Jagannath Temple complex is entered through four gates, each facing a cardinal direction, each governed by a different deity. The Singhadwara on the east is the main entrance for devotees. Two stone lions flank it, and the flagpole above — the Nilachakra — is visible for miles, even from the sea.\\n\\nNon-Hindus are not permitted inside. This is not cruelty but theology: the outer world is considered impure in a way that is incompatible with the sanctum. A watchtower on the perimeter allows those of other faiths to glimpse the *sudarshana chakra* atop the spire.\\n\\n## Maha Prasad: Food of the Gods\\n\\nWithin the temple complex sits what may be the largest active kitchen in the world. Fifty-six varieties of food are cooked daily in earthen pots, stacked seven high over wood fires, and offered first to Lord Jagannath before being distributed as *Maha Prasad*.\\n\\nThe Ananda Bazaar — the Market of Bliss — is where the prasad is sold. The belief is profound and practical: whatever is prepared here is cooked by the goddess Mahalakshmi herself. No distinction of caste or creed applies to those who receive it. The rice and dal that I ate, wrapped in a banana leaf, were the best I have ever tasted — not because of spice or refinement, but because of what they carried.\\n\\n## The Rath Yatra\\n\\nOnce a year, the three deities — Jagannath, his brother Balabhadra, and his sister Subhadra — are brought out of the temple and placed in enormous wooden chariots. Thousands of devotees pull these chariots with ropes along the Bada Danda. It is said that merely witnessing this is sufficient for liberation.\\n\\nThe chariots are built fresh each year from specific trees — a tradition that ensures the entire structure, down to its last wooden pin, carries the energy of renewal. Nothing is recycled from the previous year's ratha.\\n\\n## The Sea at Evening\\n\\nAfter the temple, I walked to the beach. The Bay of Bengal was rough and grey, the sand black in the fading light. Fishermen were pulling nets. Children flew kites. Somewhere behind me, a thousand lamps were being lit in the name of a god who wears a smile that no human sculptor has ever fully explained.\\n\\nI sat there a long time. The wind from the sea smelled of distance.\\n\\n---\\n\\n*Timings: 5:00 AM – 12:00 AM. Entry restricted to Hindus. Nearest airport: Bhubaneswar (BBI), 60 km.*\\n\"])</script><script>self.__next_f.push([1,\"13:T9c3,\"])</script><script>self.__next_f.push([1,\"\\n## The Wheel of Time\\n\\nImagine that you are the sun. You need a chariot to cross the sky. You need twenty-four wheels, seven horses, and walls covered in every expression of human longing. You need Konark.\\n\\nThe Sun Temple at Konark was built in the 13th century by King Narasimhadeva I of the Eastern Ganga Dynasty. It was designed as a colossal stone chariot — the *ratha* of Surya, the sun god — with twelve pairs of intricately carved wheels representing the months of the year, drawn by seven stone horses representing the days of the week.\\n\\n## What the Stones Carry\\n\\nThe temple's exterior is an encyclopedia of medieval Indian life carved in chlorite and laterite stone. There are celestial nymphs (*apsaras*) frozen in mid-dance. There are war elephants, musicians, and astronomers. There are erotic panels in the Khajuraho tradition — not as shock, but as theology: Kama, the god of desire, is considered one of the four Purusharthas, the legitimate goals of human life.\\n\\nThe wheels are the most famous element. Each is carved with spokes that function as sundials — the shadow of each spoke tells the time of day with precision that shames most modern instruments. The artisans who built Konark were not merely architects. They were scientists.\\n\\n## The Missing Spire\\n\\nThe main *shikhara* — the tower above the sanctum — collapsed sometime in the 18th or 19th century. No one recorded exactly when or why. The stone that remains is the *jagamohana*, the audience hall, which the British archaeologists filled with sand to stabilize it when they feared its imminent collapse.\\n\\nThere is something instructive in this: even in its damaged state, Konark is one of the most complex religious structures ever built. What it was when complete is almost beyond imagining.\\n\\n## The Sound of the Sea\\n\\nThe temple was built within sight of the sea. The Bay of Bengal is visible from the upper terraces, and in ancient times, the *Padma Stone* — a powerful magnet lodged in the pinnacle — was said to keep ships from approaching the coast. Whether this is myth or physics remains unresolved.\\n\\nWhat is certain is that the light here behaves differently. In the hour before sunset, the stone glows like heated copper. The wheels cast long shadows that slowly rotate, as they have been doing for eight hundred years, counting time in a language older than any alphabet.\\n\\n---\\n\\n*Entry: ₹40 (Indian nationals), ₹600 (foreign nationals). Sunrise visits recommended. Open daily 6 AM – 8 PM.*\\n\"])</script><script>self.__next_f.push([1,\"14:Tb41,\"])</script><script>self.__next_f.push([1,\"\\n## A Temple That Breathes\\n\\nMost ancient temples are museums. Lingaraj is not. It is a living organism — a 55-metre tower (*deula*) rising above a compound that contains 150 smaller shrines, all actively worshipped, all still tended by hereditary priests whose families have served here since the 11th century.\\n\\nThe presiding deity is *Harihara* — a form combining Shiva and Vishnu, a theological compromise in a city where both traditions met and merged. The primary *linga* in the sanctum is not carved from stone. It is *swayambhu* — self-manifested. It emerged from the earth. The priests pour milk and water over it daily; the overflow runs in channels through the temple floor and exits into a sacred tank.\\n\\n## The Architecture of Devotion\\n\\nKalinga architecture follows strict rules. The *rekha deula* (tower) rises in a convex curve that has been mathematically described as a *catenary* — the shape a heavy chain makes when hung between two points. This was not accidental. The ancient *Shilpa Shastras* (architectural manuals) prescribed these proportions precisely because they distribute weight with extraordinary efficiency.\\n\\nThe walls are covered in carvings arranged in horizontal bands. At the base are elephants — stability, the foundation of the earth. Above them, horses — movement, time. Above them, humans in every conceivable pose. Higher still, the celestial beings. The order is cosmological: rising from the material to the divine.\\n\\n## The Bindu Sagar\\n\\nBehind Lingaraj lies the Bindu Sagar — a sacred tank said to contain water drawn from every holy river and lake in India. During the *Ashokastami* festival, the Lingaraj deity is brought out and given a ritual bath in this tank, an event attended by hundreds of thousands of pilgrims.\\n\\nThe tank is surrounded by smaller temples — some crumbling, some actively maintained. Priests bathe here at dawn. Children swim. Turtles drift in the shallows. A heron stands motionless on the far bank, apparently unimpressed by any of it.\\n\\n## The View from the Platform\\n\\nNon-Hindus are not permitted inside the main compound, but the Archaeological Survey of India has built a raised viewing platform on the north wall that allows a clear view of the great tower. On the morning I climbed it, the *deula* was catching the early light on its upper half while its base remained in deep shadow — a gradient of gold and darkness that no photograph I took came close to capturing.\\n\\nA guide named Prakash, who had been showing visitors the temple for forty years, stood beside me. \\\"People come from all over the world,\\\" he said, not proudly, just observationally. \\\"And the temple doesn't care. It was here before they came, and it will be here after.\\\"\\n\\nHe was, of course, absolutely right.\\n\\n---\\n\\n*Location: Old Town, Bhubaneswar. Active Hindu temple — dress code applies. Viewing platform open to all.*\\n\"])</script><script>self.__next_f.push([1,\"15:Tbec,\"])</script><script>self.__next_f.push([1,\"\\n## The Golden Triangle\\n\\nOdisha's three sacred cities — Bhubaneswar, Konark, and Puri — form a triangle across the coastal plain that archaeologists call a pilgrimage circuit and that travellers call an education in what human beings are capable of building when they believe in something with their entire civilization.\\n\\nI drove the triangle in three days. That is not enough time. It is, however, enough time to understand why you need to come back.\\n\\n## Day One: The Temple City\\n\\nBhubaneswar earned its title \\\"the temple city of India\\\" the old-fashioned way — by building, at various points between the 7th and 12th centuries, an estimated seven thousand temples. About five hundred survive in varying states of preservation.\\n\\nThe Lingaraj Temple is the crown. But the real discovery, for me, was the cluster of smaller temples in the Old Town — the Parashurameshwar, the Mukteshvara (with its extraordinary *torana*, a carved stone gateway that represents the high-water mark of Kalinga decorative art), and the Rajarani, named not for royalty but for the particular red-and-gold sandstone — *raja rani* stone — from which it is built.\\n\\n## Day Two: The Wheel\\n\\nKonark in the early morning is cold and quiet. I arrived before the gates opened and walked around the outer perimeter of the *jagamohana* while the light was still horizontal and gold. The stone wheels cast their shadows across the sand. A peacock called from somewhere inside the protected enclosure. A man was performing yoga on the lawn, facing the east.\\n\\nThe Archaeological Survey of India has done good work here in recent decades — stabilizing the structure, clearing encroachments, lighting the site carefully at night. The sound-and-light show in the evening is theatrical but surprisingly moving.\\n\\n## Day Three: Puri and the Sea\\n\\nThe road from Konark to Puri runs along the coast. For stretches of it, you can see both the temple spires and the ocean simultaneously. This corridor — sacred architecture and primordial water — is one of the great visual experiences available in India.\\n\\nPuri itself is two cities layered on top of each other. The pilgrimage city is ancient, dense, organized around the Jagannath Temple like a wheel around its axle. The beach town is modern, loud, and entirely separate in spirit. The skill is to inhabit both simultaneously — to eat *mahaprasad* at noon and watch the sunset over the Bay of Bengal in the evening.\\n\\n## What Remains\\n\\nI drove back to Bhubaneswar on the last day with the particular feeling that travel through places of genuine spiritual power tends to produce: not peace exactly, not excitement, but a kind of recalibration. The ordinary world had been briefly shown its own ordinariness. The extraordinary had been briefly shown to be possible.\\n\\nThe temples of Odisha do not ask for belief. They ask only for attention. That is a much harder thing, and a much more rewarding one.\\n\\n---\\n\\n*Best months to visit: October to March. The Rath Yatra at Puri (June/July) draws millions and requires advance planning.*\\n\"])</script><script>self.__next_f.push([1,\"c:[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"min-h-screen pt-20\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-7xl mx-auto px-6 py-16\\\",\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"mb-14 space-y-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs tracking-[0.25em] uppercase text-terracotta font-medium\\\",\\\"children\\\":\\\"Sacred Journeys\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"font-display text-5xl md:text-6xl text-warm-stone leading-tight\\\",\\\"children\\\":\\\"Odisha's Living Heritage\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-stone-500 max-w-lg text-lg leading-relaxed\\\",\\\"children\\\":\\\"Pilgrimage essays, temple histories, and cinematic travel writing from the soul of eastern India.\\\"}]]}],[\\\"$\\\",\\\"$Lf\\\",null,{\\\"articles\\\":[{\\\"slug\\\":\\\"maa-biraja-shakti-peetha\\\",\\\"title\\\":\\\"Maa Biraja: The Navel of the World\\\",\\\"excerpt\\\":\\\"Among the 51 Shakti Peethas, Maa Biraja at Jajpur holds a singular position — it is said to mark the spot where the navel of the goddess fell to earth.\\\",\\\"category\\\":\\\"Pilgrimage\\\",\\\"location\\\":\\\"Jajpur, Odisha\\\",\\\"coverImage\\\":\\\"https://images.unsplash.com/photo-1605330889276-80dc48464670?q=80\\u0026w=1600\\\",\\\"publishedAt\\\":\\\"2024-05-01T00:00:00.000Z\\\",\\\"status\\\":\\\"published\\\",\\\"scheduledFor\\\":\\\"$undefined\\\",\\\"views\\\":978,\\\"shares\\\":41,\\\"tags\\\":[\\\"Shakti Peetha\\\",\\\"Jajpur\\\",\\\"Goddess\\\",\\\"Tantric\\\",\\\"Pilgrimage\\\"],\\\"content\\\":\\\"$10\\\"},{\\\"slug\\\":\\\"chausath-yogini-temple\\\",\\\"title\\\":\\\"The Sixty-Four Yoginis of Hirapur\\\",\\\"excerpt\\\":\\\"Hidden in a field nine kilometres from Bhubaneswar, a circular roofless temple holds sixty-four yoginis in sandstone — among the rarest religious sites in India.\\\",\\\"category\\\":\\\"Temple\\\",\\\"location\\\":\\\"Hirapur, Odisha\\\",\\\"coverImage\\\":\\\"https://images.unsplash.com/photo-1620766182578-02435699aa59?q=80\\u0026w=1600\\\",\\\"publishedAt\\\":\\\"2024-04-05T00:00:00.000Z\\\",\\\"status\\\":\\\"published\\\",\\\"scheduledFor\\\":\\\"$undefined\\\",\\\"views\\\":1244,\\\"shares\\\":63,\\\"tags\\\":[\\\"Yogini\\\",\\\"Tantric\\\",\\\"Hirapur\\\",\\\"Shakti\\\",\\\"Rare Temple\\\"],\\\"content\\\":\\\"$11\\\"},{\\\"slug\\\":\\\"puri-jagannath-temple\\\",\\\"title\\\":\\\"Puri: The Lord's Abode\\\",\\\"excerpt\\\":\\\"Where the Char Dham meets the sea — a journey to the sacred kingdom of Lord Jagannath, master of the universe.\\\",\\\"category\\\":\\\"Pilgrimage\\\",\\\"location\\\":\\\"Puri, Odisha\\\",\\\"coverImage\\\":\\\"https://images.unsplash.com/photo-1566804968393-27d9753c2289?q=80\\u0026w=1600\\\",\\\"publishedAt\\\":\\\"2024-03-15T00:00:00.000Z\\\",\\\"status\\\":\\\"published\\\",\\\"scheduledFor\\\":\\\"$undefined\\\",\\\"views\\\":2847,\\\"shares\\\":142,\\\"tags\\\":[\\\"Jagannath\\\",\\\"Char Dham\\\",\\\"Rath Yatra\\\",\\\"Puri\\\",\\\"Vaishnava\\\"],\\\"content\\\":\\\"$12\\\"},{\\\"slug\\\":\\\"konark-sun-temple\\\",\\\"title\\\":\\\"Konark: The Sun Chariot\\\",\\\"excerpt\\\":\\\"A 13th-century stone chariot built to carry the god of light across the sky — and what remains when the light itself has faded.\\\",\\\"category\\\":\\\"Temple\\\",\\\"location\\\":\\\"Konark, Odisha\\\",\\\"coverImage\\\":\\\"https://images.unsplash.com/photo-1591807353982-bfa33e83b4c6?q=80\\u0026w=1600\\\",\\\"publishedAt\\\":\\\"2024-02-20T00:00:00.000Z\\\",\\\"status\\\":\\\"published\\\",\\\"scheduledFor\\\":\\\"$undefined\\\",\\\"views\\\":3521,\\\"shares\\\":198,\\\"tags\\\":[\\\"Konark\\\",\\\"UNESCO\\\",\\\"Kalinga Architecture\\\",\\\"Sun Temple\\\",\\\"Stone Carving\\\"],\\\"content\\\":\\\"$13\\\"},{\\\"slug\\\":\\\"lingaraj-temple\\\",\\\"title\\\":\\\"Lingaraj: The King of Lingas\\\",\\\"excerpt\\\":\\\"Bhubaneswar's oldest and largest temple is a living monument — thousands gather here daily, as they have for eleven centuries.\\\",\\\"category\\\":\\\"Temple\\\",\\\"location\\\":\\\"Bhubaneswar, Odisha\\\",\\\"coverImage\\\":\\\"https://images.unsplash.com/photo-1627894483216-2138af692e32?q=80\\u0026w=1600\\\",\\\"publishedAt\\\":\\\"2024-01-10T00:00:00.000Z\\\",\\\"status\\\":\\\"published\\\",\\\"scheduledFor\\\":\\\"$undefined\\\",\\\"views\\\":1932,\\\"shares\\\":87,\\\"tags\\\":[\\\"Lingaraj\\\",\\\"Bhubaneswar\\\",\\\"Shaiva\\\",\\\"Kalinga\\\",\\\"Living Temple\\\"],\\\"content\\\":\\\"$14\\\"},{\\\"slug\\\":\\\"odisha-sacred-odyssey\\\",\\\"title\\\":\\\"An Odisha Sacred Odyssey\\\",\\\"excerpt\\\":\\\"From the temple-city of Bhubaneswar to the ocean at Puri, a journey through the living architecture of eastern India's spiritual heritage.\\\",\\\"category\\\":\\\"Pilgrimage\\\",\\\"location\\\":\\\"Odisha, India\\\",\\\"coverImage\\\":\\\"https://images.unsplash.com/photo-1477587458883-47145ed94245?q=80\\u0026w=1600\\\",\\\"publishedAt\\\":\\\"2024-01-01T00:00:00.000Z\\\",\\\"status\\\":\\\"published\\\",\\\"scheduledFor\\\":\\\"$undefined\\\",\\\"views\\\":4102,\\\"shares\\\":231,\\\"tags\\\":[\\\"Odisha\\\",\\\"Golden Triangle\\\",\\\"Bhubaneswar\\\",\\\"Konark\\\",\\\"Puri\\\",\\\"Road Trip\\\"],\\\"content\\\":\\\"$15\\\"}]}]]}]}],null,\\\"$L16\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"d:[\\\"$\\\",\\\"$1\\\",\\\"h\\\",{\\\"children\\\":[null,[[\\\"$\\\",\\\"$L17\\\",null,{\\\"children\\\":\\\"$L18\\\"}],null],[\\\"$\\\",\\\"$L19\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"hidden\\\":true,\\\"children\\\":[\\\"$\\\",\\\"$1a\\\",null,{\\\"fallback\\\":null,\\\"children\\\":\\\"$L1b\\\"}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"1c:I[4431,[],\\\"OutletBoundary\\\"]\\n1e:I[5278,[],\\\"AsyncMetadataOutlet\\\"]\\n16:[\\\"$\\\",\\\"$L1c\\\",null,{\\\"children\\\":[\\\"$L1d\\\",[\\\"$\\\",\\\"$L1e\\\",null,{\\\"promise\\\":\\\"$@1f\\\"}]]}]\\n\"])</script><script>self.__next_f.push([1,\"18:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1\\\"}]]\\n\"])</script><script>self.__next_f.push([1,\"1d:null\\n\"])</script><script>self.__next_f.push([1,\"20:I[622,[],\\\"IconMark\\\"]\\n\"])</script><