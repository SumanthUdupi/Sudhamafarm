{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/[slug]/layout,_N_T_/blog/[slug]/page,_N_T_/blog/chausath-yogini-temple"}},"html":"<!DOCTYPE html><!--pTeeMOXNqgU3IeRE5uq15--><html lang=\"en\" class=\"scroll-smooth\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=16&amp;q=75 16w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=3840&amp;q=75 3840w\" imageSizes=\"32px\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" imageSizes=\"100vw\"/><link rel=\"stylesheet\" href=\"/_next/static/css/c7b65dae731102a0.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4772d34723bd25e0.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f84124391a7dac4.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-a430cf81584ded6e.js\" async=\"\"></script><script src=\"/_next/static/chunks/205-40222df77b709121.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/239-0efcf3b33fe933aa.js\" async=\"\"></script><script src=\"/_next/static/chunks/845-b60c57e3c3d88dde.js\" async=\"\"></script><script src=\"/_next/static/chunks/519-a2fc4ab551bfbf28.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-53d672cf50e67ebc.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/blog/%5Bslug%5D/page-e76cb158f82cf2c0.js\" async=\"\"></script><title>The Sixty-Four Yoginis of Hirapur | SuDhama</title><meta name=\"description\" content=\"Hidden in a field nine kilometres from Bhubaneswar, a circular roofless temple holds sixty-four yoginis in sandstone — among the rarest religious sites in India.\"/><meta property=\"og:title\" content=\"The Sixty-Four Yoginis of Hirapur\"/><meta property=\"og:description\" content=\"Hidden in a field nine kilometres from Bhubaneswar, a circular roofless temple holds sixty-four yoginis in sandstone — among the rarest religious sites in India.\"/><meta property=\"og:image\" content=\"https://images.unsplash.com/photo-1620766182578-02435699aa59?q=80&amp;w=1600\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"The Sixty-Four Yoginis of Hirapur\"/><meta name=\"twitter:description\" content=\"Hidden in a field nine kilometres from Bhubaneswar, a circular roofless temple holds sixty-four yoginis in sandstone — among the rarest religious sites in India.\"/><meta name=\"twitter:image\" content=\"https://images.unsplash.com/photo-1620766182578-02435699aa59?q=80&amp;w=1600\"/><link rel=\"icon\" href=\"/images/Favicon.png\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div class=\"fixed inset-0 z-[999] flex flex-col items-center justify-center cursor-pointer select-none\" style=\"background:#111a14;opacity:0\"><div class=\"absolute inset-0 opacity-20\" style=\"background-image:url(&#x27;https://www.transparenttextures.com/patterns/subtle-grain.png&#x27;)\"></div><div class=\"relative mb-8\" style=\"opacity:0;transform:scale(0.85)\"><div class=\"relative w-20 h-20\"><img alt=\"SuDhama\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain brightness-[10] opacity-90\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=3840&amp;q=75\"/></div></div><p class=\"text-[0.6rem] tracking-[0.5em] uppercase text-white/40 mb-3\" style=\"font-family:&#x27;Inter&#x27;, sans-serif;opacity:0;transform:translateY(8px)\">Welcome to</p><h1 class=\"text-white text-5xl sm:text-6xl font-bold tracking-tight leading-none mb-2\" style=\"font-family:&#x27;Playfair Display&#x27;, serif;opacity:0;transform:translateY(16px)\">SuDhama</h1><p class=\"text-white/50 text-2xl mb-6\" style=\"font-family:&#x27;Noto Sans Kannada&#x27;, sans-serif;opacity:0\">ಸುಧಾಮ</p><div class=\"w-12 h-px bg-white/20 mb-6 origin-center\" style=\"transform:scaleX(0)\"></div><p class=\"text-[0.6rem] tracking-[0.4em] uppercase text-white/30\" style=\"font-family:&#x27;Inter&#x27;, sans-serif;opacity:0\">Hebri · Udupi · Karnataka</p><p class=\"absolute bottom-12 text-[0.55rem] tracking-[0.4em] uppercase text-white/30\" style=\"font-family:&#x27;Inter&#x27;, sans-serif;opacity:0\">Tap to enter</p></div><div id=\"read-progress\" style=\"width:0%\" aria-hidden=\"true\"></div><a href=\"#main-content\" class=\"sr-only focus:not-sr-only focus:absolute focus:z-50 top-4 left-4 bg-white text-black p-4 rounded-lg\">Skip to main content</a><header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-white border-b border-stone-100\"><div class=\"max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between\"><a class=\"flex-shrink-0 flex items-center gap-2.5\" href=\"/\"><div class=\"relative w-8 h-8\"><img alt=\"SuDhama\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"32px\" srcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=16&amp;q=75 16w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=32&amp;q=75 32w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=48&amp;q=75 48w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=64&amp;q=75 64w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=96&amp;q=75 96w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=128&amp;q=75 128w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75 256w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=384&amp;q=75 384w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2FLogo.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=3840&amp;q=75\"/></div><span class=\"font-playfair text-base font-semibold tracking-wide transition-colors duration-300 text-stone-800\">SuDhama</span></a><nav class=\"hidden md:flex items-center gap-1\"><a class=\"font-inter text-[0.72rem] tracking-wide px-3.5 py-2 rounded-sm transition-colors duration-200 text-stone-600 hover:text-terracotta\" href=\"/#farmhouse\">The Farmhouse</a><a class=\"font-inter text-[0.72rem] tracking-wide px-3.5 py-2 rounded-sm transition-colors duration-200 text-stone-600 hover:text-terracotta\" href=\"/#farm\">Our Farm</a><a class=\"font-inter text-[0.72rem] tracking-wide px-3.5 py-2 rounded-sm transition-colors duration-200 text-stone-600 hover:text-terracotta\" href=\"/#cows\">Our Cows</a><a class=\"font-inter text-[0.72rem] tracking-wide px-3.5 py-2 rounded-sm transition-colors duration-200 text-stone-600 hover:text-terracotta\" href=\"/#story\">Our Story</a><a class=\"font-inter text-[0.72rem] tracking-wide px-3.5 py-2 rounded-sm transition-colors duration-200 text-stone-600 hover:text-terracotta\" href=\"/blog\">Sacred Journeys</a></nav><button type=\"button\" class=\"md:hidden flex flex-col justify-center gap-[5px] w-9 h-9 p-1.5\" aria-label=\"Toggle menu\" aria-expanded=\"false\"><span class=\"block h-px w-full transition-all duration-300  bg-stone-700\"></span><span class=\"block h-px w-full transition-all duration-300  bg-stone-700\"></span><span class=\"block h-px w-full transition-all duration-300  bg-stone-700\"></span></button></div></header><main id=\"main-content\"><div class=\"min-h-screen transition-colors duration-700\" style=\"background-color:#0D0A07;color:#F5E6C8;font-family:&quot;Inter&quot;, system-ui, sans-serif\"><div class=\"relative h-[70vh] min-h-[480px] overflow-hidden\"><img alt=\"The Sixty-Four Yoginis of Hirapur\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1620766182578-02435699aa59%3Fq%3D80%26w%3D1600&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0\" style=\"background:linear-gradient(to bottom, rgba(139,0,0,0.35), rgba(10,10,10,0.85))\"></div><div class=\"absolute inset-0 flex flex-col items-center justify-center text-center px-6\" style=\"opacity:0;transform:translateY(40px)\"><span class=\"text-xs tracking-[0.3em] uppercase mb-4 font-medium\" style=\"color:#D4AF37\">Temple</span><h1 class=\"text-4xl sm:text-5xl md:text-6xl lg:text-7xl max-w-4xl leading-tight\" style=\"font-family:&quot;Cinzel&quot;, &quot;Playfair Display&quot;, serif;color:#FFFFFF\">The Sixty-Four Yoginis of Hirapur</h1><p class=\"mt-6 text-white/70 max-w-xl text-lg leading-relaxed\">Hidden in a field nine kilometres from Bhubaneswar, a circular roofless temple holds sixty-four yoginis in sandstone — among the rarest religious sites in India.</p><div class=\"mt-8 flex items-center gap-4 text-white/50 text-sm\"><span>📍 <!-- -->Hirapur, Odisha</span><span>5 April 2024</span></div></div></div><div class=\"relative\"><div class=\"absolute inset-0 pointer-events-none opacity-20\" style=\"background:radial-gradient(ellipse at 20% 30%, #2A1F0D 0%, transparent 60%)\"></div><div class=\"relative z-10 max-w-3xl mx-auto px-6 py-16\"><div class=\"animate-fade-up\"><div class=\"flex flex-wrap gap-2 mb-8\"><span class=\"text-xs px-3 py-1 rounded-full border font-medium\" style=\"background:#2A1F0D;color:#D4AF37;border-color:#D4AF3740;border-radius:0.25rem\">Yogini</span><span class=\"text-xs px-3 py-1 rounded-full border font-medium\" style=\"background:#2A1F0D;color:#D4AF37;border-color:#D4AF3740;border-radius:0.25rem\">Tantric</span><span class=\"text-xs px-3 py-1 rounded-full border font-medium\" style=\"background:#2A1F0D;color:#D4AF37;border-color:#D4AF3740;border-radius:0.25rem\">Hirapur</span><span class=\"text-xs px-3 py-1 rounded-full border font-medium\" style=\"background:#2A1F0D;color:#D4AF37;border-color:#D4AF3740;border-radius:0.25rem\">Shakti</span><span class=\"text-xs px-3 py-1 rounded-full border font-medium\" style=\"background:#2A1F0D;color:#D4AF37;border-color:#D4AF3740;border-radius:0.25rem\">Rare Temple</span></div><article class=\"prose prose-lg max-w-none prose-themed\" style=\"color:#F5E6C8;font-family:&quot;Inter&quot;, system-ui, sans-serif\"><h2>What the Fields Hide</h2>\n<p>There is no signboard that adequately prepares you. You turn off the main road at a junction marked only by a chai stall, follow a narrow track through rice fields, and then — in a clearing, surrounded by nothing remarkable — you find it.</p>\n<p>The Chausath Yogini Temple at Hirapur is circular. It is roofless. It is barely nine metres in diameter. And it contains sixty-four yogini figures carved into niches along its inner wall that are unlike anything else in Indian religious art.</p>\n<h2>The Yoginis Themselves</h2>\n<p>Each of the sixty-four is a form of the divine feminine — powerful, autonomous, iconographically distinct. They carry different weapons, wear different expressions, stand on different vahanas (animal vehicles). Some are serene. Several are terrifying. A few are explicitly erotic. All are carved with a roughness, an immediacy, that differs sharply from the refined polish of mainstream temple sculpture.</p>\n<p>Yogini worship belongs to the Tantric tradition — a strand of Indian spirituality that has always occupied the boundary between the sanctioned and the transgressive. The yoginis are practitioners, not passive figures. They hold power. Their iconography reflects this.</p>\n<p>The presiding goddess stands in the centre of the inner courtyard: Maheshvari, eight-armed, above a buffalo. The quality of light that enters this roofless space falls differently depending on the time of day, illuminating different figures as the sun moves.</p>\n<h2>The Archaeology</h2>\n<p>The temple dates to approximately the 9th century CE. It was rediscovered by scholars only in 1953. There is a second, less-visited Chausath Yogini temple at Ranipur-Jharial in western Odisha; the two are the only circular yogini temples that survive in India.</p>\n<p>Why circular? The form may reflect a ritual practice in which initiates circumambulated the figures during ceremony. Or it may be cosmological — the circle as mandala, the sixty-four as a numerological completeness. The texts are silent on this. The temple simply stands.</p>\n<h2>The Silence Here</h2>\n<p>I arrived on a weekday afternoon. There was one other visitor, a young woman from Kolkata doing her PhD on Tantric iconography. The caretaker sat under a tree outside, reading a newspaper.</p>\n<p>Inside the circle, the only sound was wind through the open roof. The yoginis looked outward from their niches, toward the rice fields, toward the distant highway, toward whatever they have been looking at for eleven hundred years.</p>\n<p>I sat on the floor in the centre of the circle for a long time, not meditating exactly, just being still in a place that asked for stillness.</p>\n<p>The woman from Kolkata came and sat nearby. We didn&#x27;t speak. We didn&#x27;t need to.</p>\n<hr/>\n<p><em>Location: Hirapur village, ~9 km from Bhubaneswar. ASI protected. Open daily sunrise to sunset.</em></p></article><div class=\"mt-16 pt-8 border-t\" style=\"border-color:#D4AF3730\"><a class=\"text-sm font-medium transition-opacity hover:opacity-70\" style=\"color:#D4AF37\" href=\"/blog\">← Back to Sacred Journeys</a></div></div></div></div></div><!--$--><!--/$--></main><footer class=\"bg-stone-900 text-stone-400 py-14 mt-0 border-t border-stone-800\"><div class=\"max-w-6xl mx-auto px-6 md:px-10\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-stone-800\"><div class=\"space-y-3\"><img alt=\"SuDhama\" loading=\"lazy\" width=\"88\" height=\"40\" decoding=\"async\" data-nimg=\"1\" class=\"h-10 w-auto brightness-[2] opacity-80\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=96&amp;q=75 1x, /_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2FLogo.png&amp;w=256&amp;q=75\"/><p class=\"text-stone-500 text-xs leading-relaxed max-w-[220px]\">A good home. A good life.<br/>Kanyana Village, Udupi.</p></div><div><p class=\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\">Navigate</p><ul class=\"space-y-2\"><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#farmhouse\">The Farmhouse</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#farm\">Our Farm</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#cows\">Our Cows</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/#story\">Our Story</a></li><li><a class=\"text-sm text-stone-400 hover:text-white transition-colors\" href=\"/blog\">Sacred Journeys</a></li></ul></div><div><p class=\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\">Contact</p><address class=\"not-italic text-sm text-stone-400 leading-relaxed space-y-1\"><p>Kanyana Village, Hebri Taluk</p><p>Udupi, Karnataka — 576112</p><a href=\"mailto:contact@sudhamafarms.com\" class=\"block mt-2 hover:text-white transition-colors\">contact@sudhamafarms.com</a></address></div></div><div class=\"pt-6 flex flex-col sm:flex-row justify-between text-[0.65rem] text-stone-600 tracking-wide\"><p>© <!-- -->2026<!-- --> SuDhama. All rights reserved.</p><p class=\"mt-2 sm:mt-0\">Hebri · Udupi · Karnataka</p></div></div></footer><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><script src=\"/_next/static/chunks/webpack-4772d34723bd25e0.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__ne