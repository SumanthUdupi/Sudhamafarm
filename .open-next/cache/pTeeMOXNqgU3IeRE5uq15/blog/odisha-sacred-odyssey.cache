e\":\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\",\"children\":\"Navigate\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"/#farmhouse\",{\"children\":[\"$\",\"$L7\",null,{\"href\":\"/#farmhouse\",\"className\":\"text-sm text-stone-400 hover:text-white transition-colors\",\"children\":\"The Farmhouse\"}]}],[\"$\",\"li\",\"/#farm\",{\"children\":[\"$\",\"$L7\",null,{\"href\":\"/#farm\",\"className\":\"text-sm text-stone-400 hover:text-white transition-colors\",\"children\":\"Our Farm\"}]}],[\"$\",\"li\",\"/#cows\",{\"children\":[\"$\",\"$L7\",null,{\"href\":\"/#cows\",\"className\":\"text-sm text-stone-400 hover:text-white transition-colors\",\"children\":\"Our Cows\"}]}],[\"$\",\"li\",\"/#story\",{\"children\":[\"$\",\"$L7\",null,{\"href\":\"/#story\",\"className\":\"text-sm text-stone-400 hover:text-white transition-colors\",\"children\":\"Our Story\"}]}],[\"$\",\"li\",\"/blog\",{\"children\":[\"$\",\"$L7\",null,{\"href\":\"/blog\",\"className\":\"text-sm text-stone-400 hover:text-white transition-colors\",\"children\":\"Sacred Journeys\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-[0.6rem] tracking-[0.3em] uppercase text-stone-600 mb-4 font-medium\",\"children\":\"Contact\"}],[\"$\",\"address\",null,{\"className\":\"not-italic text-sm text-stone-400 leading-relaxed space-y-1\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Kanyana Village, Hebri Taluk\"}],[\"$\",\"p\",null,{\"children\":\"Udupi, Karnataka — 576112\"}],[\"$\",\"a\",null,{\"href\":\"mailto:contact@sudhamafarms.com\",\"className\":\"block mt-2 hover:text-white transition-colors\",\"children\":\"contact@sudhamafarms.com\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"pt-6 flex flex-col sm:flex-row justify-between text-[0.65rem] text-stone-600 tracking-wide\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" SuDhama. All rights reserved.\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 sm